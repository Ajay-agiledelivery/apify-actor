{
  "actorOutputSchemaVersion": 1,
  "title": "Naukri Job Results",
  "description": "Fresh job listings scraped from Naukri.com",
  "views": {
    "overview": {
      "title": "Jobs Table",
      "transformation": {
        "fields": ["title","company","location","experience","salary","postedDate","tags","openings","applicants","jobUrl","scrapedAt"]
      },
      "display": {
        "component": "table",
        "properties": {
          "title":      { "label": "Job Title",   "format": "text" },
          "company":    { "label": "Company",     "format": "text" },
          "location":   { "label": "Location",    "format": "text" },
          "experience": { "label": "Experience",  "format": "text" },
          "salary":     { "label": "Salary",      "format": "text" },
          "postedDate": { "label": "Posted",      "format": "text" },
          "tags":       { "label": "Skills",      "format": "text" },
          "openings":   { "label": "Openings",    "format": "text" },
          "applicants": { "label": "Applicants",  "format": "text" },
          "jobUrl":     { "label": "Apply Link",  "format": "link" },
          "scrapedAt":  { "label": "Scraped At",  "format": "text" }
        }
      }
    }
  }
}
